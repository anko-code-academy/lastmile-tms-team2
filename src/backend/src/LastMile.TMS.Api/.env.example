# Generate DASHBOARD__PASSWORDHASH with:
# docker run --rm caddy:2-alpine caddy hash-password --plaintext "your-password"
# In this .env file, escape each "$" as "$$" for docker compose env_file.
Email__SendGridApiKey=
Email__FromEmail=
Email__FromName=
Storage__Endpoint=http://localhost:9000
Storage__AccessKey=minioadmin
Storage__SecretKey=minioadmin
Storage__Region=us-east-1
Storage__BucketName=lastmile-binaries
Storage__ForcePathStyle=true
Storage__AutoCreateBucket=true
Mapbox__AccessToken=
Mapbox__GeocodingBaseUrl=https://api.mapbox.com/search/geocode/v6
Mapbox__NavigationBaseUrl=https://api.mapbox.com
DASHBOARD__USERNAME=
DASHBOARD__PASSWORD=
DASHBOARD__PASSWORDHASH=
