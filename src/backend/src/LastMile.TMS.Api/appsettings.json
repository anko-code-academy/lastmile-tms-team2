{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=lastmile_tms;Username=postgres;Password=postgres",
    "HangfireConnection": "Host=localhost;Port=5432;Database=lastmile_tms;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "AdminCredentials": {
    "Email": "admin@lastmile.com",
    "Password": "Admin@12345"
  },
  "Authentication": {
    "AccessTokenLifetimeMinutes": 60,
    "RefreshTokenLifetimeDays": 14
  },
  "Frontend": {
    "BaseUrl": "http://localhost",
    "AllowedOrigins": [
      "http://localhost",
      "http://localhost:3000"
    ]
  },
  "Storage": {
    "Endpoint": "http://localhost:9000",
    "Region": "us-east-1",
    "BucketName": "lastmile-binaries",
    "ForcePathStyle": true,
    "AutoCreateBucket": true
  },
  "Mapbox": {
    "AccessToken": "",
    "GeocodingBaseUrl": "https://api.mapbox.com",
    "NavigationBaseUrl": "https://api.mapbox.com"
  },
  "Email": {
    "FromEmail": "",
    "FromName": "",
    "SendGridApiKey": ""
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.Seq"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "serverUrl": "http://localhost:5341" } }
    ]
  },
  "AllowedHosts": "*"
}
